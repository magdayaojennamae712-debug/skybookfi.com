// ============================================================
// SkyBook — Firestore Security Rules
// These rules ensure:
// - Users can only read/write their OWN data
// - Nobody can read other users' data
// - Admin (owner email) can read and manage all cashback data
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the current user the site owner/admin?
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'magdayaojennamae712@gmail.com';
    }

    // BOOKINGS collection
    match /bookings/{bookingId} {

      // ✅ Users can READ their own bookings only
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;

      // ✅ Users can CREATE a booking for themselves only
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId
                    && request.resource.data.userId is string
                    && request.resource.data.bookingRef is string
                    && request.resource.data.totalPrice is string;

      // ✅ Users can UPDATE only the status field of their OWN booking
      // (for cancellations)
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status'])
                    && request.resource.data.s