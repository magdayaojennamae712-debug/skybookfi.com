# NordicWings .gitignore — protects secrets from GitHub

# NEVER commit secrets
.env
.env.local
.env.production
.env.staging
*.pem
*.key
serviceAccountKey.json
firebase-adminsdk*.json

# Dependencies
node_modules/

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*

# Build
dist/
build/
.cache/

# IDE
.vscode/
.idea/

# Large image files
public/skybook_*.png
public/nordicwings_*.png
